<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameServerApp.UI.ViewModels"
             xmlns:models="using:GameServerApp.Core.Models"
             xmlns:conv="using:GameServerApp.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="GameServerApp.UI.Views.ServerConsoleView"
             x:DataType="vm:ServerConsoleViewModel">

    <UserControl.Resources>
        <conv:ConsoleOutputLevelToBrushConverter x:Key="LevelToBrush" />
        <conv:ServerStateToBrushConverter x:Key="StateToBrush" />
        <conv:ServerStateToTextConverter x:Key="StateToText" />
    </UserControl.Resources>

    <DockPanel Margin="0">

        <!-- Header Bar -->
        <Border DockPanel.Dock="Top"
                Background="#1F1F1F"
                Padding="20,12"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10"
                             Fill="{Binding ServerState, Converter={StaticResource StateToBrush}}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ServerName}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#E0E0E0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ServerState, Converter={StaticResource StateToText}}"
                               FontSize="12"
                               Foreground="#666666"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Start"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding CanStart}"
                            Padding="14,6"
                            Background="#22C55E"
                            Foreground="White"
                            CornerRadius="5"
                            FontSize="12"
                            FontWeight="Medium" />
                    <Button Content="Stop"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding CanStop}"
                            Padding="14,6"
                            Background="#EF4444"
                            Foreground="White"
                            CornerRadius="5"
                            FontSize="12"
                            FontWeight="Medium" />
                    <Button Content="Restart"
                            Command="{Binding RestartCommand}"
                            IsEnabled="{Binding CanStop}"
                            Padding="14,6"
                            Background="#2A2A2A"
                            Foreground="#E0E0E0"
                            CornerRadius="5"
                            FontSize="12"
                            FontWeight="Medium" />
                    <Border Width="1" Background="#2A2A2A" Margin="4,0" />
                    <Button Content="Settings"
                            Command="{Binding OpenConfigCommand}"
                            Padding="14,6"
                            Background="#2A2A2A"
                            Foreground="#E0E0E0"
                            CornerRadius="5"
                            FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Server Info Bar -->
        <Border DockPanel.Dock="Top"
                Background="#181818"
                Padding="20,6"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Port:" FontSize="11" Foreground="#666666" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Port}" FontSize="11" Foreground="#E0E0E0" VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas, monospace" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Version:" FontSize="11" Foreground="#666666" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Version}" FontSize="11" Foreground="#E0E0E0" VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas, monospace" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Players:" FontSize="11" Foreground="#666666" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding OnlinePlayers, StringFormat='{}{0}'}" FontSize="11" Foreground="#0EA5E9" VerticalAlignment="Center" FontWeight="Medium" FontFamily="Cascadia Mono, Consolas, monospace" />
                    <TextBlock Text="{Binding MaxPlayers, StringFormat='/ {0}'}" FontSize="11" Foreground="#555555" VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas, monospace" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Command Input -->
        <Border DockPanel.Dock="Bottom"
                Background="#151515"
                Padding="12,8"
                BorderBrush="#2A2A2A"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding CommandText}"
                         PlaceholderText="Type a command..."
                         Background="#0D0D0D"
                         Foreground="#E0E0E0"
                         BorderBrush="#2A2A2A"
                         CornerRadius="5"
                         Padding="10,8"
                         FontFamily="Cascadia Mono, Consolas, monospace"
                         FontSize="13"
                         x:Name="CommandInput" />
                <Button Grid.Column="1"
                        Content="Send"
                        Command="{Binding SendCommandCommand}"
                        Margin="8,0,0,0"
                        Padding="16,8"
                        Background="#0EA5E9"
                        Foreground="White"
                        CornerRadius="5"
                        FontSize="12"
                        FontWeight="Medium" />
            </Grid>
        </Border>

        <!-- Console Output -->
        <Border Background="#0D0D0D" Margin="0">
            <ListBox ItemsSource="{Binding ConsoleOutput}"
                     Background="Transparent"
                     Padding="12,8"
                     x:Name="ConsoleOutputList">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0,1" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                    <Style Selector="ListBoxItem /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#1A1A2E" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ConsoleOutputLine">
                        <TextBlock Text="{Binding Text}"
                                   Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

    </DockPanel>
</UserControl>
