<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameServerApp.UI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400"
             x:Class="GameServerApp.UI.Views.SystemLogView"
             x:DataType="vm:SystemLogViewModel">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#111111"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <CheckBox Content="Auto-scroll"
                              IsChecked="{Binding AutoScroll}"
                              Foreground="#888888"
                              FontSize="12"
                              VerticalAlignment="Center" />
                    <Button Content="Clear"
                            Command="{Binding ClearLogsCommand}"
                            Padding="10,4"
                            Background="#2A2A2A"
                            Foreground="#E0E0E0"
                            CornerRadius="4"
                            FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="🖥"
                               FontSize="16"
                               VerticalAlignment="Center" />
                    <TextBlock Text="System Log"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#E0E0E0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LogLines.Count, StringFormat='({0} entries)'}"
                               FontSize="12"
                               Foreground="#555555"
                               VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Log output -->
        <ListBox ItemsSource="{Binding LogLines}"
                 Name="LogListBox"
                 Background="#0A0A0A"
                 Foreground="#C0C0C0"
                 FontFamily="Cascadia Mono, Consolas, monospace"
                 FontSize="12"
                 Padding="8,4">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="4,1" />
                    <Setter Property="MinHeight" Value="18" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="#1E3A5F" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#1A1A1A" />
                </Style>
            </ListBox.Styles>
        </ListBox>
    </DockPanel>
</UserControl>
