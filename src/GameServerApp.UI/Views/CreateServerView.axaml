<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameServerApp.UI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="GameServerApp.UI.Views.CreateServerView"
             x:DataType="vm:CreateServerViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,40" MaxWidth="500" HorizontalAlignment="Left">

            <!-- Title -->
            <TextBlock Text="{Binding GameDisplayName, StringFormat='New {0} Server'}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,8" />
            <TextBlock Text="Configure your server settings and we'll handle the rest."
                       FontSize="14"
                       Foreground="#888888"
                       Margin="0,0,0,32" />

            <!-- Server Name -->
            <TextBlock Text="Server Name"
                       FontSize="13"
                       FontWeight="Medium"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,6" />
            <TextBox Text="{Binding ServerName}"
                     PlaceholderText="My Awesome Server"
                     Background="#222222"
                     Foreground="#E0E0E0"
                     BorderBrush="#2A2A2A"
                     CornerRadius="5"
                     Padding="12,10"
                     FontSize="14"
                     Margin="0,0,0,20" />

            <!-- Server Version -->
            <TextBlock Text="Server Version"
                       FontSize="13"
                       FontWeight="Medium"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,6" />

            <!-- Loading indicator -->
            <StackPanel IsVisible="{Binding IsLoadingVersions}"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,0,0,20">
                <ProgressBar IsIndeterminate="True"
                             Width="120"
                             Height="3"
                             Foreground="#0EA5E9"
                             CornerRadius="1" />
                <TextBlock Text="Loading versions..."
                           FontSize="12"
                           Foreground="#666666"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Version ComboBox -->
            <ComboBox ItemsSource="{Binding AvailableVersions}"
                      SelectedItem="{Binding SelectedVersion}"
                      IsVisible="{Binding !IsLoadingVersions}"
                      PlaceholderText="Select a version"
                      Background="#222222"
                      Foreground="#E0E0E0"
                      BorderBrush="#2A2A2A"
                      CornerRadius="5"
                      Padding="12,8"
                      FontSize="14"
                      HorizontalAlignment="Stretch"
                      MaxDropDownHeight="300"
                      Margin="0,0,0,20">
                <ComboBox.Styles>
                    <Style Selector="ComboBox /template/ Popup > Border">
                        <Setter Property="Background" Value="#222222" />
                        <Setter Property="BorderBrush" Value="#2A2A2A" />
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                    <Style Selector="ComboBoxItem">
                        <Setter Property="Foreground" Value="#E0E0E0" />
                        <Setter Property="Padding" Value="12,8" />
                        <Setter Property="FontSize" Value="13" />
                    </Style>
                    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#2A2A2A" />
                    </Style>
                    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#0EA5E9" />
                    </Style>
                </ComboBox.Styles>
            </ComboBox>

            <!-- Memory -->
            <TextBlock Text="Memory (MB)"
                       FontSize="13"
                       FontWeight="Medium"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,6" />
            <NumericUpDown Value="{Binding MemoryMb}"
                           Minimum="512"
                           Maximum="16384"
                           Increment="256"
                           Background="#222222"
                           Foreground="#E0E0E0"
                           BorderBrush="#2A2A2A"
                           CornerRadius="5"
                           Padding="12,8"
                           FontSize="14"
                           Margin="0,0,0,24"
                           FormatString="N0" />

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#EF4444"
                       FontSize="13"
                       Margin="0,0,0,12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Progress -->
            <StackPanel IsVisible="{Binding IsCreating}" Margin="0,0,0,16">
                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding DownloadProgress, StringFormat='{}{0:P0}'}"
                               FontSize="12"
                               Foreground="#0EA5E9"
                               FontWeight="Medium" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               Foreground="#E0E0E0"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
                <ProgressBar Value="{Binding DownloadProgress}"
                             Maximum="1"
                             Height="6"
                             CornerRadius="3"
                             Foreground="#0EA5E9" />
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Create Server"
                        Command="{Binding CreateServerCommand}"
                        IsEnabled="{Binding !IsCreating}"
                        Padding="20,10"
                        Background="#0EA5E9"
                        Foreground="White"
                        CornerRadius="6"
                        FontWeight="Medium"
                        FontSize="14" />
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding !IsCreating}"
                        Padding="20,10"
                        Background="#2A2A2A"
                        Foreground="#E0E0E0"
                        CornerRadius="6"
                        FontSize="14" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
