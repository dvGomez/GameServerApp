<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GameServerApp.UI.ViewModels"
        xmlns:conv="using:GameServerApp.UI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="GameServerApp.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Game Server Manager"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        Background="#0F0F0F">

    <Window.Resources>
        <conv:ServerStateToBrushConverter x:Key="StateToBrush" />
        <conv:ServerStateToTextConverter x:Key="StateToText" />
    </Window.Resources>

    <Grid ColumnDefinitions="240,*">

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#111111"
                BorderBrush="#1E1E1E"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,8">
                    <TextBlock Text="Game Server"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#E0E0E0" />
                    <TextBlock Text="Manager"
                               FontSize="18"
                               FontWeight="Light"
                               Foreground="#888888"
                               Margin="0,0,0,16" />

                    <Button Content="+ New Server"
                            Command="{Binding CreateNewServerCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="12,8"
                            Background="#0EA5E9"
                            Foreground="White"
                            CornerRadius="6"
                            FontWeight="Medium" />
                </StackPanel>

                <!-- Separator -->
                <Border DockPanel.Dock="Top"
                        Height="1"
                        Background="#1E1E1E"
                        Margin="16,8,16,8" />

                <!-- Server label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="SERVERS"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#555555"
                           Margin="16,8,16,4"
                           LetterSpacing="1" />

                <!-- Server list -->
                <ListBox ItemsSource="{Binding SidebarItems}"
                         SelectedItem="{Binding SelectedSidebarItem}"
                         Background="Transparent"
                         Margin="8,4,8,8">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="CornerRadius" Value="6" />
                            <Setter Property="Margin" Value="0,1" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1E1E1E" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1A1A1A" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SidebarItemViewModel">
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                <Ellipse Grid.Column="0" Grid.RowSpan="2"
                                         Width="8" Height="8"
                                         Fill="{Binding State, Converter={StaticResource StateToBrush}}"
                                         Margin="4,0,10,0"
                                         VerticalAlignment="Center" />
                                <DockPanel Grid.Column="1" Grid.Row="0">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding PlayerInfo}"
                                               FontSize="11"
                                               Foreground="#0EA5E9"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                    <TextBlock Text="{Binding ServerName}"
                                               FontSize="13"
                                               Foreground="#E0E0E0"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Version}"
                                               FontSize="10"
                                               Foreground="#555555" />
                                    <TextBlock Text="{Binding Port, StringFormat=':{0}'}"
                                               FontSize="10"
                                               Foreground="#555555" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="#1A1A1A">
            <TransitioningContentControl Content="{Binding CurrentPage}" />
        </Border>

    </Grid>
</Window>
